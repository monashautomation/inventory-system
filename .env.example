BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
OLLAMA_URL=
OLLAMA_MODEL=
OLLAMA_AUTH_TOKEN=
MCP_ENDPOINT=

KIOSK_SECRET=
VITE_KIOSK_SECRET=

# Label Printer

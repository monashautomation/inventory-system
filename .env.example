# Metrics
METRICS_ENABLED=false
METRICS_USERNAME=
METRICS_PASSWORD=
METRICS_PRUSA_ENABLED=true
METRICS_BAMBU_ENABLED=true
# legacy: existing mapped bambulab_* metrics from /status polling
# prometheus: pass through Bambuddy native metrics from /api/v1/metrics
# prefer prometheus and fall back to legacy if it fails
METRICS_BAMBU_SOURCE=prometheus
